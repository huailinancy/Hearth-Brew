# Hearth & Brew — API Keys
# Copy this file to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
RUNWAY_API_KEY=...

# Facebook Page Access Token (from developers.facebook.com/tools/explorer)
